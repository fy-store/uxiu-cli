{
  "type": "module",
  "name": "uxiu-cli",
  "version": "0.9.1",
  "packageManager": "pnpm@11.0.6",
  "description": "快速创建 koa 项目工具",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "uxiu-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:create": "tsx ./tests/create.ts",
    "test:build": "tsx ./tests/build.ts"
  },
  "keywords": [
    "uxiu-cli",
    "uxiu"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "./dist",
    "*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fy-store/uxiu-cli.git"
  },
  "author": "feiYu <feiyucode@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.0",
    "@types/yargs": "^17.0.35",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@oxc-project/runtime": "^0.138.0",
    "adm-zip": "^0.5.18",
    "dayjs": "^1.11.21",
    "event-imt": "^0.2.7",
    "execa": "^9.6.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0",
    "yargs": "^18.0.0"
  }
}
